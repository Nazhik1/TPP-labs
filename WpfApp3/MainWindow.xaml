<Window x:Class="WpfApp3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp3"
        mc:Ignorable="d"
        Title="MainWindow" Height="800" Width="1400" MinHeight="400" MinWidth="700">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"></ColumnDefinition>
            <ColumnDefinition Width="3*">
            </ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition MinHeight="50" ></RowDefinition>
        </Grid.RowDefinitions>
        <StackPanel>
            <Button x:Name="add" Content="Добавить" Height="25" Grid.Column="0" Grid.Row="0" Click="Add"/>
            <Button x:Name="del" Content="Удалить" Height="25" Grid.Column="0" Grid.Row="0" Click="Del"/>
        </StackPanel>
        <ListBox x:Name="Zam" Grid.Column="0" Grid.Row="1" Height="auto" Width="auto" FontSize="20">
        </ListBox>
        <TextBox Text="Название" Grid.Row="0" Grid.Column="1" FontSize="40" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
        <TextBox Text="Заметка текст" Grid.Row="1" Grid.Column="1" FontSize="40" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
    </Grid>
</Window>
